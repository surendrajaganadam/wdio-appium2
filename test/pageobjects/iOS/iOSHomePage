class iOSHomePage {
get addToCartButton() {
return $('(//XCUIElementTypeOther[@name="test-ADD TO CART"])[1]')
}

get cartLogo() {
return $('~test-Cart')
}

get sideMenu() {
return $('~test-Menu')
}

get logoutButton(){

return $('~test-LOGOUT')
}

async logoutFromApp(){
await browser.pause(600)
await safeTap(this.sideMenu)
await this.logoutButton.click()
await browser.pause(2000)
}

async addProductToCart() {
await this.addToCartButton.click()
await browser.pause(600)
await safeTap(this.cartLogo)
await browser.pause(2000)
}




}

async function safeTap(element){
try{
await element.click()
}catch {}

const loc = await element.getLocation()
const size = await element.getSize()

const x = Math.floor(loc.x + size.width/2)
const y = Math.floor(loc.y + size.height/2)

const safeY = Math.max(y, 70)
await driver.execute('mobile: tap', {x:x, y:safeY})

}

export default new iOSHomePage()